{
  "codex": {
    "transport": "codex-background-bash",
    "contract": "docs/codex-implementer-contract.md",
    "tools": ["Bash"],
    "domains": {
      "ui": "forbidden",
      "ai-harness": "forbidden",
      "backend": "preferred",
      "general": "allowed"
    }
  },
  "sonnet": {
    "transport": "claude-subagent",
    "agent": "slice-implementer-sonnet",
    "tools": ["Read", "Edit", "Write", "Bash"],
    "domains": {
      "ui": "preferred",
      "ai-harness": "preferred",
      "backend": "allowed",
      "general": "preferred"
    }
  },
  "experts": {
    "ui": {
      "id": "reviewer-ui",
      "legacy_id": "expert-ui",
      "prompt": "lib/codex-bridge/prompts/reviewer-ui.md",
      "phases": ["spec-review", "post-implementation-review"],
      "domains": ["ui"]
    },
    "ux": {
      "id": "reviewer-ux",
      "legacy_id": "expert-ux",
      "prompt": "lib/codex-bridge/prompts/reviewer-ux.md",
      "phases": ["spec-review"],
      "domains": ["ui"]
    },
    "architecture": {
      "id": "reviewer-architecture",
      "legacy_id": "expert-architecture",
      "prompt": "lib/codex-bridge/prompts/reviewer-architecture.md",
      "phases": ["spec-review", "pre-dispatch", "post-implementation-review"],
      "domains": ["backend", "ai-harness", "general", "ui"]
    },
    "backend": {
      "id": "reviewer-backend",
      "legacy_id": "expert-backend",
      "prompt": "lib/codex-bridge/prompts/reviewer-backend.md",
      "phases": ["spec-review", "post-implementation-review"],
      "domains": ["backend"]
    },
    "ai-harness": {
      "id": "reviewer-ai-harness",
      "legacy_id": "expert-ai-harness",
      "prompt": "lib/codex-bridge/prompts/reviewer-ai-harness.md",
      "phases": ["spec-review", "post-implementation-review"],
      "domains": ["ai-harness"]
    },
    "test": {
      "id": "reviewer-test",
      "legacy_id": "expert-test",
      "prompt": "lib/codex-bridge/prompts/reviewer-test.md",
      "phases": ["spec-review", "pre-dispatch", "post-implementation-review"],
      "domains": ["general"]
    },
    "security": {
      "id": "reviewer-security",
      "legacy_id": "expert-security",
      "prompt": "lib/codex-bridge/prompts/reviewer-security.md",
      "phases": ["spec-review", "post-implementation-review"],
      "domains": ["backend", "ai-harness"]
    }
  }
}
