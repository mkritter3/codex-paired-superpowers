# node_modules is intentionally NOT ignored — Claude Code does not run
# `npm install` on plugin install (marketplace or --plugin-dir), so the
# plugin's runtime deps (proper-lockfile + its 3 transitive pure-JS deps,
# ~200KB total, zero native bindings) are vendored alongside the source.
# See episodic-memory plugin for the same pattern.

.DS_Store
*.log
# sidecar files generated during real runs (not test fixtures)
docs/specs/*.codex.json
# autopilot active-run anchor (transient)
.codex-paired/
# v0.4.1+ sidecar location (transient runtime state by default;
# explicit `git mv` from slice 4 preserved tracked audit trails)
.superpowers-codex-paired/

# v0.7.0 worktree-isolation directory for autopilot subagent dispatch
.git-worktrees/
