{
  "description": "codex-paired-superpowers hooks: provenance verification + v0.7.3.1 mailbox auto-injection for Sonnet subagents",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/check-commit-provenance.sh\""
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/mailbox-inject.sh\""
          }
        ]
      }
    ]
  }
}
